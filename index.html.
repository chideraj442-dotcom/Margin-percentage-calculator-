<!DOCTYPE html>
<html lang="en-GB">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gold Lot Size Calculator</title>
    <style>
        body { font-family: sans-serif; background: #f4f7f6; display: flex; justify-content: center; padding: 20px; }
        .card { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.1); width: 100%; max-width: 400px; }
        h2 { color: #2c3e50; text-align: center; }
        label { display: block; margin-top: 15px; font-weight: bold; color: #555; }
        input { width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; font-size: 16px; }
        .result-box { margin-top: 25px; padding: 15px; background: #e8f5e9; border-radius: 8px; text-align: center; }
        #result { font-size: 24px; font-weight: bold; color: #2e7d32; }
    </style>
</head>
<body>
    <div class="card">
        <h2>Gold Lot Calculator 📈</h2>
        
        <label>Account Size ($)</label>
        <input type="number" id="accSize" value="50000" oninput="calculate()">

        <label>Margin Percentage (%)</label>
        <input type="number" id="marginPercent" value="10" oninput="calculate()">

        <label>Leverage (1:X)</label>
        <input type="number" id="leverage" value="10" oninput="calculate()">

        <label>Current Gold Price ($)</label>
        <input type="number" id="price" value="4600" oninput="calculate()">

        <label>Contract Size (Ounces)</label>
        <input type="number" id="contract" value="100" oninput="calculate()">

        <div class="result-box">
            <div>Recommended Lot Size:</div>
            <div id="result">0.11</div>
        </div>
    </div>

    <script>
        function calculate() {
            const accSize = document.getElementById('accSize').value;
            const marginPercent = document.getElementById('marginPercent').value / 100;
            const leverage = document.getElementById('leverage').value;
            const price = document.getElementById('price').value;
            const contract = document.getElementById('contract').value;

            if (price > 0 && leverage > 0) {
                const targetMargin = accSize * marginPercent;
                const marginPerLot = (price * contract) / leverage;
                const lotSize = targetMargin / marginPerLot;
                document.getElementById('result').innerText = lotSize.toFixed(2);
            }
        }
    </script>
</body>
</html>
